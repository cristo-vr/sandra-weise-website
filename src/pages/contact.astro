---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contact"
  description="Get in touch with Sandra Weise. Whether it's a question, an inquiry, or just to say hello."
>
  <!-- Hero -->
  <section class="page-hero bg-espresso">
    <div class="container">
      <p class="section-label">Contact</p>
      <h1>Let's <span class="accent">connect</span>.</h1>
      <p class="page-hero__desc">Have a question, a collaboration idea, or just want to say hello? I'd love to hear from you.</p>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="section bg-cream">
    <div class="container contact-layout">
      <div class="contact-form-wrapper">
        <form id="contact-form" class="contact-form" novalidate>
          <div class="form-group">
            <label for="name" class="form-label">Name</label>
            <input type="text" id="name" name="name" class="form-input" required placeholder="Your full name" />
          </div>

          <div class="form-group">
            <label for="email" class="form-label">Email</label>
            <input type="email" id="email" name="email" class="form-input" required placeholder="you@example.com" />
          </div>

          <div class="form-group">
            <label for="subject" class="form-label">Subject</label>
            <select id="subject" name="subject" class="form-input form-select" required>
              <option value="" disabled selected>What's this about?</option>
              <option value="Coaching inquiry">Coaching inquiry</option>
              <option value="Speaking engagement">Speaking engagement</option>
              <option value="Media / press">Media / press</option>
              <option value="Collaboration">Collaboration</option>
              <option value="General">General hello</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message" class="form-label">Message</label>
            <textarea id="message" name="message" class="form-input form-textarea" required placeholder="Tell me a bit about what's on your mind..." rows="5"></textarea>
          </div>

          <!-- Cloudflare Turnstile widget -->
          <div class="cf-turnstile" data-sitekey="YOUR_TURNSTILE_SITE_KEY" data-theme="light"></div>

          <button type="submit" class="btn btn--primary form-submit" id="submit-btn">
            <span class="submit-text">Send Message</span>
            <span class="submit-loading" style="display: none;">Sending...</span>
          </button>

          <div id="form-status" class="form-status" role="alert"></div>
        </form>
      </div>

      <div class="contact-info">
        <div class="contact-info__card">
          <h3>Other ways to reach me</h3>

          <div class="contact-info__item">
            <span class="contact-info__label">Email</span>
            <a href="mailto:sandra@sandraweise.com">sandra@sandraweise.com</a>
          </div>

          <div class="contact-info__item">
            <span class="contact-info__label">Location</span>
            <p>St. Paul, Minnesota</p>
          </div>

          <div class="contact-info__item">
            <span class="contact-info__label">Social</span>
            <div class="contact-info__socials">
              <a href="https://www.instagram.com/sandraweise/" target="_blank" rel="noopener noreferrer">Instagram</a>
              <a href="https://www.linkedin.com/in/sandraweise/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
              <a href="https://www.youtube.com/@sandraweise" target="_blank" rel="noopener noreferrer">YouTube</a>
            </div>
          </div>
        </div>

        <div class="contact-info__card contact-info__card--accent">
          <h4>Looking to book Sandra?</h4>
          <p>For coaching sessions and speaking engagements, head to the booking page for available times and pricing.</p>
          <a href="/work-with-me" class="btn btn--accent btn--small" style="margin-top: 1rem;">Book Sandra &rarr;</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero {
    padding: calc(72px + var(--space-xl)) 0 var(--space-xl);
  }

  .page-hero h1 {
    color: var(--linen);
  }

  .page-hero__desc {
    margin-top: 1rem;
    font-size: 1.125rem;
    color: rgba(250, 246, 240, 0.6);
    max-width: 480px;
  }

  .accent { color: var(--citrine); }

  /* Layout */
  .contact-layout {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-dark);
  }

  .form-input {
    width: 100%;
    padding: 0.875rem 1rem;
    border: 1.5px solid var(--border-subtle);
    border-radius: 0.75rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: var(--text-dark);
    background: white;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    appearance: none;
    -webkit-appearance: none;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--indigo);
    box-shadow: 0 0 0 3px rgba(61, 79, 143, 0.1);
  }

  .form-input::placeholder {
    color: var(--sand);
  }

  .form-select {
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%237A7068' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
    cursor: pointer;
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-submit {
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  .form-status {
    font-size: 0.9375rem;
    padding: 0;
    border-radius: 0.75rem;
    transition: all 0.3s ease;
  }

  .form-status.success {
    padding: 1rem;
    background: rgba(61, 153, 112, 0.08);
    color: var(--forest);
    border: 1px solid rgba(61, 153, 112, 0.2);
  }

  .form-status.error {
    padding: 1rem;
    background: rgba(164, 52, 58, 0.08);
    color: var(--ruby);
    border: 1px solid rgba(164, 52, 58, 0.2);
  }

  /* Turnstile */
  .cf-turnstile {
    margin: 0.5rem 0;
  }

  /* Contact Info */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-info__card {
    background: white;
    border-radius: 1.5rem;
    padding: 2rem;
    box-shadow: 0 2px 12px rgba(44, 29, 18, 0.06);
  }

  .contact-info__card h3 {
    margin-bottom: 1.5rem;
    font-size: 1.25rem;
  }

  .contact-info__item {
    margin-bottom: 1.25rem;
  }

  .contact-info__item:last-child {
    margin-bottom: 0;
  }

  .contact-info__label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  .contact-info__item a,
  .contact-info__item p {
    font-size: 0.9375rem;
    color: var(--text-dark);
  }

  .contact-info__item a:hover {
    color: var(--indigo);
  }

  .contact-info__socials {
    display: flex;
    gap: 1rem;
  }

  .contact-info__socials a {
    font-size: 0.9375rem;
    color: var(--text-dark);
    transition: color 0.2s ease;
  }

  .contact-info__socials a:hover {
    color: var(--indigo);
  }

  .contact-info__card--accent {
    background: var(--espresso);
  }

  .contact-info__card--accent h4 {
    color: var(--linen);
    margin-bottom: 0.75rem;
  }

  .contact-info__card--accent p {
    color: rgba(250, 246, 240, 0.6);
    font-size: 0.9375rem;
    line-height: 1.6;
  }
</style>

<!-- Cloudflare Turnstile Script -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn')!;
  const statusEl = document.getElementById('form-status')!;
  const submitText = submitBtn.querySelector('.submit-text')!;
  const submitLoading = submitBtn.querySelector('.submit-loading')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Get Turnstile token
    const turnstileInput = form.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement;
    const token = turnstileInput?.value;

    if (!token) {
      statusEl.className = 'form-status error';
      statusEl.textContent = 'Please complete the verification challenge.';
      return;
    }

    // UI feedback
    (submitBtn as HTMLButtonElement).disabled = true;
    (submitText as HTMLElement).style.display = 'none';
    (submitLoading as HTMLElement).style.display = 'inline';
    statusEl.className = 'form-status';
    statusEl.textContent = '';

    const formData = new FormData(form);
    const data = {
      name: formData.get('name'),
      email: formData.get('email'),
      subject: formData.get('subject'),
      message: formData.get('message'),
      token,
    };

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        statusEl.className = 'form-status success';
        statusEl.textContent = 'Message sent! Sandra will be in touch.';
        form.reset();
        // Reset Turnstile
        if (window.turnstile) {
          window.turnstile.reset();
        }
      } else {
        const err = await res.json().catch(() => ({ error: 'Something went wrong.' }));
        statusEl.className = 'form-status error';
        statusEl.textContent = err.error || 'Something went wrong. Please try again.';
      }
    } catch {
      statusEl.className = 'form-status error';
      statusEl.textContent = 'Network error. Please try again.';
    } finally {
      (submitBtn as HTMLButtonElement).disabled = false;
      (submitText as HTMLElement).style.display = 'inline';
      (submitLoading as HTMLElement).style.display = 'none';
    }
  });
</script>
