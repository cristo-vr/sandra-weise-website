---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/ventures', label: 'Ventures' },
  { href: '/podcast', label: 'Podcast' },
  { href: '/work-with-me', label: 'Work With Me' },
  { href: '/contact', label: 'Contact' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="nav" id="nav">
  <a href="/" class="nav__logo" aria-label="Sandra Weise — Home">
    <img src="/images/logo-transparent.png" alt="Sandra Weise" class="nav__logo-img" />
  </a>

  <div class="nav__pill">
    <nav class="nav__links" aria-label="Main navigation">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={['nav__link', { 'nav__link--active': isActive(link.href) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <a href="/work-with-me" class="btn btn--accent btn--small nav__cta">Book Sandra</a>
  </div>

  <button
    class="nav__toggle"
    id="nav-toggle"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="nav-mobile"
  >
    <span class="nav__toggle-bar"></span>
    <span class="nav__toggle-bar"></span>
    <span class="nav__toggle-bar"></span>
  </button>

  <nav class="nav__mobile" id="nav-mobile" aria-label="Mobile navigation">
    {links.map((link) => (
      <a
        href={link.href}
        class:list={['nav__mobile-link', { 'nav__mobile-link--active': isActive(link.href) }]}
      >
        {link.label}
      </a>
    ))}
    <a href="/work-with-me" class="btn btn--accent nav__mobile-cta">Book Sandra</a>
  </nav>
</header>

<style>
  .nav {
    position: fixed;
    top: 1.25rem;
    left: 0;
    right: 0;
    z-index: 1000;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 2rem;
    pointer-events: none;
  }

  .nav__logo,
  .nav__pill,
  .nav__toggle {
    pointer-events: auto;
  }

  .nav__logo {
    justify-self: start;
    display: flex;
    align-items: center;
  }

  .nav__logo-img {
    height: 72px;
    width: auto;
    display: block;
    transition: height 0.3s ease;
  }

  .nav--scrolled .nav__logo-img {
    height: 56px;
  }

  /* Floating pill */
  .nav__pill {
    justify-self: center;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0.5rem 0.5rem 1.5rem;
    background: rgba(250, 246, 240, 0.82);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(44, 29, 18, 0.06);
    border-radius: 999px;
    box-shadow: 0 4px 24px rgba(44, 29, 18, 0.06);
    transition: box-shadow 0.3s ease, background 0.3s ease;
  }

  .nav--scrolled .nav__pill {
    background: rgba(250, 246, 240, 0.92);
    box-shadow: 0 6px 32px rgba(44, 29, 18, 0.12);
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 0.125rem;
  }

  .nav__link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    padding: 0.5rem 0.875rem;
    border-radius: 999px;
    transition: color 0.2s ease, background 0.2s ease;
    white-space: nowrap;
  }

  .nav__link:hover {
    color: var(--espresso);
    background: rgba(44, 29, 18, 0.04);
  }

  .nav__link--active {
    color: var(--espresso);
    font-weight: 600;
    background: rgba(44, 29, 18, 0.06);
  }

  .nav__cta {
    margin-left: 0.5rem;
  }

  /* Mobile toggle */
  .nav__toggle {
    display: none;
    justify-self: end;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: rgba(250, 246, 240, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(44, 29, 18, 0.06);
    border-radius: 999px;
    box-shadow: 0 4px 24px rgba(44, 29, 18, 0.06);
  }

  .nav__toggle-bar {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--espresso);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .nav__toggle[aria-expanded="true"] .nav__toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav__toggle[aria-expanded="true"] .nav__toggle-bar:nth-child(2) {
    opacity: 0;
  }
  .nav__toggle[aria-expanded="true"] .nav__toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile full-screen overlay */
  .nav__mobile {
    display: none;
  }

  @media (max-width: 960px) {
    .nav {
      grid-template-columns: auto 1fr auto;
      top: 1rem;
      padding: 0 1.25rem;
    }

    .nav__pill {
      display: none;
    }

    .nav__logo-img {
      height: 52px;
    }

    .nav--scrolled .nav__logo-img {
      height: 44px;
    }

    .nav__toggle {
      display: flex;
    }

    .nav__mobile {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 1.5rem;
      background: var(--warm-cream);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease, visibility 0.3s ease;
      z-index: 999;
      pointer-events: auto;
    }

    .nav__mobile.is-open {
      opacity: 1;
      visibility: visible;
    }

    .nav__mobile-link {
      font-size: 1.5rem;
      color: var(--espresso);
      font-weight: 500;
    }

    .nav__mobile-link--active {
      color: var(--citrine);
    }

    .nav__mobile-cta {
      margin-top: 1.5rem;
    }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('nav--scrolled', window.scrollY > 10);
  });

  const toggle = document.getElementById('nav-toggle');
  const mobile = document.getElementById('nav-mobile');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
    mobile?.classList.toggle('is-open', !isOpen);
    document.body.style.overflow = isOpen ? '' : 'hidden';
  });

  mobile?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      mobile.classList.remove('is-open');
      document.body.style.overflow = '';
    });
  });
</script>
